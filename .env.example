# Supabase — required for Google OAuth sign-in and experiment event logging.
# Leave both blank to run in local demo mode (console.log only, no real
# Supabase writes, YouTube connect uses simulated data).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Direct Google OAuth (alternative to Supabase-managed auth) for the
# YouTube Data API + Analytics API. Set VITE_USE_REAL_OAUTH=true only
# after you've added your deployed URL as an Authorized redirect URI
# and Authorized JavaScript origin in Google Cloud Console.
VITE_USE_REAL_OAUTH=false
VITE_GOOGLE_CLIENT_ID=
